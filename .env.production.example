# Production Environment Variables for Coolify Deployment
# Copy this file and configure your actual values in Coolify's environment settings

# Security (REQUIRED - CHANGE IN PRODUCTION)
SECRET_KEY=your-very-long-random-secret-key-min-32-characters

# Admin Credentials (REQUIRED - CHANGE IN PRODUCTION)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-secure-password

# Database (SQLite by default, persisted in volume)
DATABASE_URL=sqlite:///./pim.db

# CORS (Set to your domain in production)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# JWT Token Expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# External PIM Integration (Optional - only if importing from external PIM)
PIM_BASE_URL=https://pim.gruposvan.com:7005
PIM_MAIL=your-pim-email@example.com
PIM_PASSWORD=your-pim-password
PIM_SSL_VERIFY=true
